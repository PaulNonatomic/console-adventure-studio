		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.0",
		"jsdom": "^29.1.1",
		"typescript": "^5.7.0",
		"vite": "^5.4.0",
		"vitest": "^4.1.7"
	}
}
