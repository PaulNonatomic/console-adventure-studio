{
	"name": "console-adventure-studio",
	"version": "0.1.0",
	"private": true,
	"description": "Visual editor + visualiser for console-adventure narratives. React Flow on top of console-adventure's JSON schema.",
	"author": "Paul Stamp <paul@nonatomic.co.uk> (https://nonatomic.co.uk)",
	"license": "MIT",
	"homepage": "https://github.com/PaulNonatomic/console-adventure-studio",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PaulNonatomic/console-adventure-studio.git"
	},
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
